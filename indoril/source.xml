<?xml version="1.0" encoding="utf-8" ?>
<elements>
    <info>
        <update version="0.0.2">
            <file name="source.xml" url="https://raw.githubusercontent.com/caterplease/indoril/master/indoril/source.xml" />
        </update>
    </info>
    <element name="Realms of Indoril" type="Source" source="Core" id="ID_LT_SOURCE_REALMS_OF_INDORIL">
        <description>
            <p>Explore the various realms originating from the planet Indoril, its moons, pasts, futures, and possibilities between.</p>
        </description>
        <setters>
            <set name="abbreviation">ROI</set>
            <set name="url">https://startplaying.games/gm/cm9hqzoml0064wu4zwkwu8eg3</set>
            <set name="author" abbreviation="LT" url="https://startplaying.games/gm/cm9hqzoml0064wu4zwkwu8eg3">DM Erin</set>
            <set name="image">https://raw.githubusercontent.com/caterplease/indoril/master/dm_avt.jpg</set>
            <set name="third-party">true</set>
            <set name="supplement">true</set>
            <set name="release">20260616</set>
        </setters>
    </element>

    <!--
        Allows selecting a free feat for Realms of Indoril characters, including those without Indoril bonuses.
    -->
    <element name="Indoril Bonus Feat" type="Option" source="Realms of Indoril" id="ID_ROI_OPTION_BONUS_FEAT">
        <description>
            <p>Enable to take the free bonus feat from Realms of Indoril games, if allowed for your game.</p>
        </description>
        <rules>
            <select type="Feat" name="Feat (Indoril)" optional="true" />
        </rules>
    </element>
    <!--
        Allows support for Realms of Indoril languages
    -->
    <element name="Indoril Languages" type="Option" source="Realms of Indoril" id="ID_ROI_OPTION_LANGUAGES">
        <description>
            <p>Enable <strong>Realms of Indoril</strong> characters to select diagetic languages native to their campaign.</p>
        </description>
    </element>
</elements>
