<?xml version="1.0" encoding="utf-8" ?>
<elements>
    <info>
        <name>Druid</name>
        <description>The Druid additions to the Realms of Indoril game series.</description>
        <update version="1.0.0">
            <file name="append-druid.xml" url="https://raw.githubusercontent.com/caterplease/indoril/master/indoril/append-druid.xml" />
        </update>
    </info>
    <!--
        Allow selecting the Realms of Indoril
        Homebrew Rules, which will activate all relevant features.
    -->
    <append name="Druid" type="Class" source="Realms of Indoril" id="ID_WOTC_PHB_CLASS_DRUID">
        <rules>

            <select type="Feat" name="Realms of Indoril Rules" supports="ID_ROI_RULES_DRUID" optional="true" />
        </rules>
    </append>
    <!--
        Specific feat displaying the actual homebrew being added with Indoril
        rules, including HTML for formatting.
    -->
    <element name="Realms of Indoril Rules (Druid)" type="Feat" source="Realms of Indoril" id="ID_ROI_RULES_DRUID">
        <supports>ID_ROI_RULES_DRUID</supports>
        <requirements>!ID_ROI_RULES</requirements>
        <description>
            <p>Update your class to be compatible with the <strong>Realms of Indoril</strong> series of games. This will replace certain class features, add new ones, and augment existing ones.</p>
            <div element="ID_ROI_CLASS_FEATURE_DRUID_SPELLCASTING" />
            <div element="ID_ROI_CLASS_FEATURE_DRUID_BEAST_SPEECH" />
            <div element="ID_ROI_CLASS_FEATURE_DRUID_SWIFT_WILDSHAPE" />
            <div element="ID_ROI_CLASS_FEATURE_DRUID_GREATER_WILDSHAPE" />
            <div element="ID_ROI_CLASS_FEATURE_DRUID_PRIMAL_RENEWAL" />
            <div element="ID_ROI_CLASS_FEATURE_DRUID_EXPANDED_WILDSHAPE" />
        </description>
        <sheet display="false" />
        <rules>
            <!-- REPLACEMENTS -->
            <grant type="Class Feature" id="ID_INTERNAL_FEATURE_REPLACEMENT_DRUID_WILD_SHAPE" />
            <!-- ADDITIONS -->
            <grant type="Class Feature" id="ID_ROI_CLASS_FEATURE_DRUID_SPELLCASTING" />
            <grant type="Class Feature" id="ID_ROI_CLASS_FEATURE_DRUID_BEAST_SPEECH" />
            <grant type="Class Feature" id="ID_ROI_CLASS_FEATURE_DRUID_SWIFT_WILDSHAPE" />
            <grant type="Class Feature" id="ID_ROI_CLASS_FEATURE_DRUID_GREATER_WILDSHAPE" level="2" />
            <grant type="Class Feature" id="ID_ROI_CLASS_FEATURE_DRUID_PRIMAL_RENEWAL" level="3" />
            <grant type="Class Feature" id="ID_ROI_CLASS_FEATURE_DRUID_EXPANDED_WILDSHAPE" level="11" />
        </rules>
    </element>

    <element name="Spellcasting" type="Class Feature" source="Realms of Indoril" id="ID_ROI_CLASS_FEATURE_DRUID_SPELLCASTING">
        <requirements>!ID_INTERNAL_FEATURE_REPLACEMENT_DRUID_SPELLCASTING</requirements>
        <description>
            <p>The number of spells you may prepare increases by <strong>4</strong>
            </p>
        </description>
        <sheet display="false" />
        <rules>
            <stat name="druid:spellcasting:prepare" value="4" />
        </rules>
    </element>
    <!-- 
        BEAST SPEECH
    -->
    <element name="Beast Speech" type="Class Feature" source="Realms of Indoril" id="ID_ROI_CLASS_FEATURE_DRUID_BEAST_SPEECH">
        <requirements>!ID_INTERNAL_FEATURE_REPLACEMENT_DRUID_BEAST_SPEECH</requirements>
        <description>
				You know "Speak with Animals" and it is always prepared. It does not count against your maximum prepared spells.
        </description>
        <sheet display="false" />
        <rules>
            <grant type="Spell" id="ID_PHB_SPELL_SPEAK_WITH_ANIMALS" spellcasting="Druid" prepared="true" />
        </rules>
    </element>
    <!--
        SWIFT WILD SHAPE
    -->
    <element name="Swift Wild Shape" type="Class Feature" source="Realms of Indoril" id="ID_ROI_CLASS_FEATURE_DRUID_SWIFT_WILDSHAPE">
        <requirements>!ID_INTERNAL_FEATURE_REPLACEMENT_DRUID_SWIFT_WILDSHAPE</requirements>
        <description>
            <p>You can use <strong>Wild Shape</strong> as a bonus action.</p>
        </description>
        <sheet display="false" />
    </element>
    <!--
        GREATER WILD SHAPE
    -->
    <element name="Greater Wild Shape" type="Class Feature" source="Realms of Indoril" id="ID_ROI_CLASS_FEATURE_DRUID_GREATER_WILDSHAPE">
        <requirements>!ID_INTERNAL_FEATURE_REPLACEMENT_DRUID_GREATER_WILDSHAPE</requirements>
        <description>
            <p>Your Wild Shape is stronger, and continues to improve as you gain Druid levels. When you use Wild Shape, the maximum challenge rating of a beast you can transform into is shown on the Greater Wild Shape table.</p>
            <p>Legendary creatures which have legendary actions of legendary resistance cannot be used with Greater Wild Shape.</p>
            <p>You cannot transform into a swarm.</p>
            <p>You must still obey the normal limitations of Wild Shape, such as restrictions on swimming and flying speeds, unless another feature says otherwise.</p>
            <h3 class="caption">Beast Shapes</h3>
            <table class="class-features">
                <thead>
                    <tr>
                        <td class="col-5">Level</td>
                        <td>Max. CR</td>
                        <td class="left">Limitations</td>
                        <td class="left">Example</td>
                    </tr>
                </thead>
                <tr>
                    <td> 2nd</td>
                    <td>1</td>
                    <td class="left">No flying or swimming speed</td>
                    <td class="left">Wolf</td>
                </tr>
                <tr>
                    <td> 4th</td>
                    <td>2</td>
                    <td class="left">No flying speed</td>
                    <td class="left">Crocodile</td>
                </tr>
                <tr>
                    <td> 6th</td>
                    <td>3</td>
                    <td class="left">No flying speed</td>
                    <td class="left">Crocodile</td>
                </tr>
                <tr>
                    <td> 8th</td>
                    <td>4</td>
                    <td class="left">—</td>
                    <td class="left">Giant eagle</td>
                </tr>
                <tr>
                    <td> 11th</td>
                    <td>5</td>
                    <td class="left">—</td>
                    <td class="left">—</td>
                </tr>
                <tr>
                    <td> 14th</td>
                    <td>6</td>
                    <td class="left">—</td>
                    <td class="left">—</td>
                </tr>
                <tr>
                    <td> 17th</td>
                    <td>7</td>
                    <td class="left">—</td>
                    <td class="left">—</td>
                </tr>
                <tr>
                    <td> 20th</td>
                    <td>8</td>
                    <td class="left">—</td>
                    <td class="left">—</td>
                </tr>
            </table>
        </description>
        <sheet action="Bonus Action" level="2" usage="{{druid wildshape:count}}/Short Rest">
            <description level="2">You can magically assume the shape of a beast that you have seen before.
			You can stay in a beast shape for {{druid wildshape:hours}} hours. You then revert to your normal form unless you expend another use of this feature. You can revert to your normal form earlier by using a bonus action on your turn. You automatically revert if you fall unconscious, drop to 0 hit points, or die.</description>
            <description level="20" usage="">You can magically assume the shape of a beast that you have seen before.
			You can stay in a beast shape for {{druid wildshape:hours}} hours. You then revert to your normal form unless you expend another use of this feature. You can revert to your normal form earlier by using a bonus action on your turn. You automatically revert if you fall unconscious, drop to 0 hit points, or die.</description>
        </sheet>
        <rules>
            <stat name="druid wildshape:hours" value="level:druid:half" />
            <stat name="druid wildshape:count" value="2" level="2" />
        </rules>
    </element>
    <!-- 
        PRIMAL RENEWAL
    -->
    <element name="Primal Renewal" type="Class Feature" source="Realms of Indoril" id="ID_ROI_CLASS_FEATURE_DRUID_PRIMAL_RENEWAL">
        <requirements>!ID_INTERNAL_FEATURE_REPLACEMENT_DRUID_PRIMAL_RENEWAL</requirements>
        <description>
            <p>Once per long rest, as a bonus action, you can expend one use of Wild Shape to restore expended spell slots.</p>
            <p>When you do so, you gain a number of renewal points equal to the maximum challenge rating of a beast you can transform into using <strong>Greater Wild Shape</strong>. You can immediately spend those points to restore one or more expended spell slots. Each spell slot restored costs a number of renewal points equal to the slots level.</p>
            <p class="indent">For example, if your maximum Greater Wild Shape challenge rating is 3, you could restore one expended 3rd-level spell slot, <strong>or</strong> one expended 2nd-level spell slot and one expended 1st-level spell slot.</p>
            <p class="indent">Any unused renewal points are lost</p>
        </description>
        <sheet>
            <description>
                <p>You may use Greater Wild Shape and Primal Renewal up to challenge rating {{druid wildshape:rating}}.</p>
            </description>
        </sheet>
        <rules>
            <stat name="druid wildshape:rating" value="1" level="2" />
            <stat name="druid wildshape:rating" value="1" level="4" />
            <stat name="druid wildshape:rating" value="1" level="6" />
            <stat name="druid wildshape:rating" value="1" level="8" />
            <stat name="druid wildshape:rating" value="1" level="11" />
            <stat name="druid wildshape:rating" value="1" level="14" />
            <stat name="druid wildshape:rating" value="1" level="17" />
            <stat name="druid wildshape:rating" value="1" level="20" />
        </rules>
    </element>
    <!-- 
        EXPANDED WILD SHAPE
    -->
    <element name="Expanded Wild Shape" type="Class Feature" source="Realms of Indoril" id="ID_ROI_CLASS_FEATURE_DRUID_EXPANDED_WILDSHAPE">
        <requirements>!ID_INTERNAL_FEATURE_REPLACEMENT_DRUID_EXPANDED_WILDSHAPE</requirements>
        <description>
            <p>At 11th level, you gain <strong>one additional</strong> use of Wild Shape.</p>
        </description>
        <sheet display="false" />
        <rules>
            <stat name="druid wildshape:count" value="1" level="11" />
        </rules>
    </element>
</elements>