<?xml version="1.0" encoding="utf-8" ?>
<elements>
    <info>
        <name>Sorcerer</name>
        <description>The Sorcerer additions to the Realms of Indoril game series.</description>
        <update version="1.0.0">
            <file name="append-sorcerer.xml" url="https://raw.githubusercontent.com/caterplease/indoril/master/indoril/append-sorcerer.xml" />
        </update>
    </info>
    <!--
        Allow selecting the Realms of Indoril
        Homebrew Rules, which will activate all relevant features.
    -->
    <append name="Sorcerer" type="Class" source="Realms of Indoril" id="ID_WOTC_PHB_CLASS_SORCERER">
        <rules>

            <select type="Feat" name="Realms of Indoril Rules" supports="ID_ROI_RULES_SORCERER" optional="true" />
        </rules>
    </append>
    <!--
        Specific feat displaying the actual homebrew being added with Indoril
        rules, including HTML for formatting.
    -->
    <element name="Realms of Indoril Rules (Sorcerer)" type="Feat" source="Realms of Indoril" id="ID_ROI_RULES_SORCERER">
        <supports>ID_ROI_RULES_SORCERER</supports>
        <requirements>!ID_ROI_RULES</requirements>
        <description>
            <p>Update your class to be compatible with the <strong>Realms of Indoril</strong> series of games. This will replace certain class features, add new ones, and augment existing ones.</p>
            <div element="ID_ROI_CLASS_FEATURE_SORCERER_SPELLCASTING" />
            <div element="ID_ROI_CLASS_FEATURE_SORCERER_EXPANDED_SPELLCASTING" />
            <div element="ID_ROI_CLASS_FEATURE_SORCERER_INNATE_METAMAGIC" />
            <div element="ID_ROI_CLASS_FEATURE_SORCERER_RECKLESS_SORCERY" />
        </description>
        <sheet display="false" />
        <rules>
            <!-- REPLACEMENTS -->
            <!-- ADDITIONS -->
            <grant type="Class Feature" id="ID_ROI_CLASS_FEATURE_SORCERER_SPELLCASTING" />
            <grant type="Class Feature" id="ID_ROI_CLASS_FEATURE_SORCERER_EXPANDED_SPELLCASTING" level="3" />
            <grant type="Class Feature" id="ID_ROI_CLASS_FEATURE_SORCERER_INNATE_METAMAGIC" level="3" />
            <grant type="Class Feature" id="ID_ROI_CLASS_FEATURE_SORCERER_RECKLESS_SORCERY" level="3" />
            <!-- FEAT -->
            <select type="Feat" name="Feat (Indoril)" optional="true" />
        </rules>
    </element>
    <!--
        SPELLCASTING
    -->
    <element name="Spellcasting" type="Class Feature" source="Realms of Indoril" id="ID_ROI_CLASS_FEATURE_SORCERER_SPELLCASTING">
        <requirements>!ID_INTERNAL_FEATURE_REPLACEMENT_SORCERER_SPELLCASTING</requirements>
        <description>
            <p>The number of spells you may prepare increases by <strong>4</strong>
            </p>
        </description>
        <sheet display="false" />
        <rules>
            <select type="Spell" name="Spellcasting (Sorcerer)" supports="$(spellcasting:list), $(spellcasting:slots)" level="1" number="4" spellcasting="Sorcerer" />
        </rules>
    </element>
    <!--
        EXPANDED SPELLCASTING
    -->
    <element name="Expanded Spellcasting" type="Class Feature" source="Realms of Indoril" id="ID_ROI_CLASS_FEATURE_SORCERER_EXPANDED_SPELLCASTING">
        <requirements>!ID_INTERNAL_FEATURE_REPLACEMENT_SORCERER_EXPANDED_SPELLCASTING</requirements>
        <description>
            <p>Starting at 3rd level, whenever you gain a Sorcerer level and learn a Sorcerer spell, you learn one additional Sorcerer spell of your choice.
            </p>
            <p>The spell must be a Sorcerer spell of a level for which you have spell slots.</p>
        </description>
        <sheet display="false" />
        <rules>
            <select type="Spell" name="Spell (Sorcerer)" supports="$(spellcasting:list),$(spellcasting:slots)" level="3" spellcasting="Sorcerer"/>
            <select type="Spell" name="Spell (Sorcerer)" supports="$(spellcasting:list),$(spellcasting:slots)" level="4" spellcasting="Sorcerer"/>
            <select type="Spell" name="Spell (Sorcerer)" supports="$(spellcasting:list),$(spellcasting:slots)" level="5" spellcasting="Sorcerer"/>
            <select type="Spell" name="Spell (Sorcerer)" supports="$(spellcasting:list),$(spellcasting:slots)" level="6" spellcasting="Sorcerer"/>
            <select type="Spell" name="Spell (Sorcerer)" supports="$(spellcasting:list),$(spellcasting:slots)" level="7" spellcasting="Sorcerer"/>
            <select type="Spell" name="Spell (Sorcerer)" supports="$(spellcasting:list),$(spellcasting:slots)" level="8" spellcasting="Sorcerer"/>
            <select type="Spell" name="Spell (Sorcerer)" supports="$(spellcasting:list),$(spellcasting:slots)" level="9" spellcasting="Sorcerer"/>
            <select type="Spell" name="Spell (Sorcerer)" supports="$(spellcasting:list),$(spellcasting:slots)" level="10" spellcasting="Sorcerer"/>
            <select type="Spell" name="Spell (Sorcerer)" supports="$(spellcasting:list),$(spellcasting:slots)" level="11" spellcasting="Sorcerer"/>
            <select type="Spell" name="Spell (Sorcerer)" supports="$(spellcasting:list),$(spellcasting:slots)" level="13" spellcasting="Sorcerer"/>
            <select type="Spell" name="Spell (Sorcerer)" supports="$(spellcasting:list),$(spellcasting:slots)" level="15" spellcasting="Sorcerer"/>
            <select type="Spell" name="Spell (Sorcerer)" supports="$(spellcasting:list),$(spellcasting:slots)" level="17" spellcasting="Sorcerer"/>
        </rules>
    </element>
    <!-- 
        INNATE METAMAGIC
    -->
    <element name="Innate Metamagic" type="Class Feature" source="Realms of Indoril" id="ID_ROI_CLASS_FEATURE_SORCERER_INNATE_METAMAGIC">
        <requirements>!ID_INTERNAL_FEATURE_REPLACEMENT_SORCERER_INNATE_METAMAGIC</requirements>
        <description>
            <p>At 3rd level, you gain the ability to twist your spells to suit your needs. You gain one of the following Metamagic options of your choice. You gain another one at 10th and 17th level.</p>
            <p class="indent">You can use only one Metamagic option on a spell when you cast it, unless otherwise noted.</p>
        </description>
        <sheet action="Bonus Action" usage="{{innate metamagic:count}}/Long Rest">
            <description level="3">
                <p>
					When you use a Metamagic option you know, you can reduce the Sorcery Point cost of that Metamagic option to 0. The Metamagic option must normally cost 1 or 2 Sorcery Points.
                </p>
            </description>
        </sheet>
        <rules>
            <select type="Class Feature" name="Innate Metamagic" supports="Metamagic" level="3" number="1"/>
            <stat name="innate metamagic:count" value="1" level="3" />
            <stat name="innate metamagic:count" value="1" level="5" />
            <stat name="innate metamagic:count" value="1" level="12" />
        </rules>
    </element>
    <!-- 
        RECKLESS SORCERY
    -->
    <element name="Reckless Sorcery" type="Class Feature" source="Realms of Indoril" id="ID_ROI_CLASS_FEATURE_SORCERER_RECKLESS_SORCERY">
        <requirements>!ID_INTERNAL_FEATURE_REPLACEMENT_SORCERER_RECKLESS_SORCERY</requirements>
        <description>
            <p>At 3rd level, you can draw on unstable magical power, granting yourself greater magical force at the cost of your own defense.</p>
            <p>You have advantage on spell attack rolls</p>
            <p>When you cast a Sorcerer spell that forces a creature to make a saving throw, you can choose one target of the spell. That target has disadvantage on its first saving throw against the spell.</p>
            <p>For the duration, attack rolls against you have advantage.</p>
            <p class="indent">At 12th level, enemies no longer have advantage against you.</p>
            <p>You can end Reckless Sorcery at any time, no action required. You may not use this feature again until you finish a long rest.</p>
        </description>
        <sheet action="Action" level="3" usage="{{reckless sorcery:count}}/Long Rest">
            <description>
                <p>
					As an action, you can enter a state of Reckless Sorcery for 1 minute.
                </p>
            </description>
        </sheet>
        <rules>
            <stat name="reckless sorcery:count" value="1" level="3" />
            <stat name="reckless sorcery:count" value="1" level="17" />
        </rules>
    </element>
</elements>